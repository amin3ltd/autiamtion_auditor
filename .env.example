# Automaton Auditor - Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED: LLM API Keys
# =============================================================================

# OpenAI API Key (for GPT-4)
OPENAI_API_KEY=sk-...

# Alternatively, use Anthropic
# ANTHROPIC_API_KEY=sk-...

# =============================================================================
# REQUIRED: LangSmith Tracing (for production debugging)
# =============================================================================

# Enable LangSmith tracing (required for LangSmith features)
LANGCHAIN_TRACING_V2=true

# Get your API key from https://smith.langchain.com/
LANGCHAIN_API_KEY=ls-...

# Project name for organizing runs
LANGCHAIN_PROJECT=automaton-auditor

# Optional: Custom endpoint (usually not needed)
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Optional: Tenant ID (usually not needed)
# LANGCHAIN_TENANT_ID=...

# =============================================================================
# OPTIONAL: Environment Configuration
# =============================================================================

# Maximum tokens for LLM responses
MAX_TOKENS=4000

# Temperature for LLM (lower = more deterministic)
LLM_TEMPERATURE=0.3

# Timeout for git clone operations (seconds)
GIT_CLONE_TIMEOUT=300

# =============================================================================
# OPTIONAL: Local LLM Providers
# =============================================================================

# LM Studio (local)
# LM_STUDIO_URL=http://localhost:1234/v1
# LM_MODEL=llama3.2:latest

# Ollama (local)
# OLLAMA_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# =============================================================================
# SECURITY: Never commit actual secrets to version control!
# =============================================================================
